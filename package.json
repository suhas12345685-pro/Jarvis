    "@types/node-cron": "^3.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
