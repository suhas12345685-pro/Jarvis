{
  "name": "jarvis",
  "version": "1.0.0",
  "description": "Autonomous AI agent with multi-modal capabilities",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "jarvis": "./dist/cli/launcher.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "setup": "tsx src/wizard.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION=1 vitest run tests/integration",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "pm2:start": "pm2 start pm2/ecosystem.config.cjs",
    "pm2:stop": "pm2 stop jarvis"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@clack/prompts": "^0.9.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.34",
    "@langchain/langgraph": "^1.2.4",
    "@langchain/openai": "^1.3.0",
    "@paypal/paypal-server-sdk": "^2.2.0",
    "@slack/bolt": "^3.21.0",
    "@slack/web-api": "^7.0.0",
    "@supabase/supabase-js": "^2.46.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "bullmq": "^5.13.0",
    "csv-parser": "^3.0.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "googleapis": "^144.0.0",
    "grammy": "^1.30.0",
    "imap-simple": "^5.1.0",
    "ioredis": "^5.4.0",
    "node-cron": "^3.0.3",
    "node-webcam": "^0.8.1",
    "nodemailer": "^6.9.0",
    "openai": "^6.32.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "razorpay": "^2.9.6",
    "screenshot-desktop": "^1.15.0",
    "stripe": "^17.0.0",
