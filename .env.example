# ─── Core ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PORT=3000

# ─── LLM Provider ───────────────────────────────────────────────────────────
# Supported: anthropic, openai, gemini, xai, deepseek, moonshot, ollama, meta, perplexity
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_MODE: "supabase" | "sqlite"
DB_MODE=sqlite
SQLITE_PATH=~/.jarvis/jarvis.db

# Supabase (only required when DB_MODE=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Queue ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_PATH=~/.jarvis/logs/app.log

# ─── Embeddings ───────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER: openai | voyage | gemini | anthropic | ollama | cohere | local
# Auto-detects from LLM_PROVIDER if not set; falls back to 'local' deterministic hash
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# ─── BYOAK — Bring Your Own API Keys ─────────────────────────────────────────

# LLM Providers (API key for the selected LLM_PROVIDER)
BYOAK_OPENAI_API_KEY=sk-...
BYOAK_GEMINI_API_KEY=AI...
BYOAK_XAI_API_KEY=xai-...
BYOAK_DEEPSEEK_API_KEY=sk-...
BYOAK_MOONSHOT_API_KEY=sk-...
BYOAK_PERPLEXITY_API_KEY=pplx-...
BYOAK_META_API_KEY=...
# Ollama runs locally — no API key needed

# Slack
BYOAK_SLACK_BOT_TOKEN=xoxb-...
BYOAK_SLACK_SIGNING_SECRET=...
BYOAK_SLACK_APP_TOKEN=xapp-...

# Telegram
BYOAK_TELEGRAM_BOT_TOKEN=...
BYOAK_TELEGRAM_WEBHOOK_SECRET=...

# Discord
BYOAK_DISCORD_BOT_TOKEN=...
BYOAK_DISCORD_APPLICATION_ID=...

# Google Chat
BYOAK_GCHAT_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# LiveKit (Voice)
BYOAK_LIVEKIT_URL=wss://...
BYOAK_LIVEKIT_API_KEY=...
BYOAK_LIVEKIT_API_SECRET=...

# Email
BYOAK_EMAIL_SMTP_HOST=smtp.gmail.com
BYOAK_EMAIL_SMTP_PORT=587
BYOAK_EMAIL_SMTP_USER=you@gmail.com
BYOAK_EMAIL_SMTP_PASS=...
BYOAK_EMAIL_IMAP_HOST=imap.gmail.com
BYOAK_EMAIL_IMAP_USER=you@gmail.com
BYOAK_EMAIL_IMAP_PASS=...

# Google Calendar
BYOAK_GCAL_CLIENT_ID=...
BYOAK_GCAL_CLIENT_SECRET=...
BYOAK_GCAL_REFRESH_TOKEN=...

# Stripe
BYOAK_STRIPE_SECRET_KEY=sk_live_...

# Razorpay
BYOAK_RAZORPAY_KEY_ID=rzp_live_...
BYOAK_RAZORPAY_KEY_SECRET=...

# PayPal
BYOAK_PAYPAL_CLIENT_ID=...
BYOAK_PAYPAL_CLIENT_SECRET=...
BYOAK_PAYPAL_ENVIRONMENT=sandbox
