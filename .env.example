ANTHROPIC_API_KEY=

LLM_PROVIDER=anthropic
LLM_MODEL=

DB_MODE=sqlite
SQLITE_PATH=~/.jarvis/jarvis.db

REDIS_URL=redis://localhost:6379
PORT=3000
LOG_PATH=~/.jarvis/logs/app.log

# BYOAK - Bring Your Own API Keys
# Channels
BYOAK_SLACK_BOT_TOKEN=
BYOAK_SLACK_SIGNING_SECRET=
BYOAK_TELEGRAM_BOT_TOKEN=
BYOAK_TELEGRAM_WEBHOOK_SECRET=
BYOAK_DISCORD_BOT_TOKEN=
BYOAK_GCHAT_SERVICE_ACCOUNT_KEY=

# Voice
BYOAK_LIVEKIT_URL=
BYOAK_LIVEKIT_API_KEY=
BYOAK_LIVEKIT_API_SECRET=

# Email
BYOAK_EMAIL_SMTP_HOST=
BYOAK_EMAIL_SMTP_PORT=587
BYOAK_EMAIL_SMTP_USER=
BYOAK_EMAIL_SMTP_PASS=
BYOAK_EMAIL_IMAP_HOST=
BYOAK_EMAIL_IMAP_USER=
BYOAK_EMAIL_IMAP_PASS=

# Calendar
BYOAK_GCAL_CLIENT_ID=
BYOAK_GCAL_CLIENT_SECRET=
BYOAK_GCAL_REFRESH_TOKEN=

# Additional LLM Providers
BYOAK_OPENAI_API_KEY=
BYOAK_GEMINI_API_KEY=
BYOAK_XAI_API_KEY=
BYOAK_DEEPSEEK_API_KEY=
BYOAK_MOONSHOT_API_KEY=
BYOAK_PERPLEXITY_API_KEY=
BYOAK_META_API_KEY=

# Payments
BYOAK_STRIPE_SECRET_KEY=
BYOAK_RAZORPAY_KEY_ID=
BYOAK_RAZORPAY_KEY_SECRET=
BYOAK_PAYPAL_CLIENT_ID=
BYOAK_PAYPAL_CLIENT_SECRET=

# Embedding Provider (optional - auto-detected from LLM provider)
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
